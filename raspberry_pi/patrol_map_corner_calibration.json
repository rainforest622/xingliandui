{
  "name": "corner-calibration-v1",
  "description": "One-corner patrol calibration: forward, right turn, forward.",
  "area_m2": 40,
  "default_speed": 0.24,
  "default_turn_speed": 0.5,
  "default_loops": 1,
  "notes": [
    "Use this before the full square patrol.",
    "It checks whether the robot can make one corner and continue along the new heading."
