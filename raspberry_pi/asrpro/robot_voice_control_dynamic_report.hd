  <block type="asr_add_id" id="reply-stop" x="460" y="140"><field name="NAME">巡检已停止，已切换为手动待命。</field><field name="id">2002</field></block>
  <block type="asr_add_id" id="reply-status" x="460" y="200"><field name="NAME">系统状态已同步到手机端。</field><field name="id">2003</field></block>
