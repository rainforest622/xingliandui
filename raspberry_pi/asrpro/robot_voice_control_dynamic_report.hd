  <block type="hardware_init" id="robot-hardware" x="1060" y="240"><statement name="DO"><block type="block_with_textarea" id="robot-volume-init"><field name="input">vol_set(7);&#10;setPinFun(13, SECOND_FUNCTION);&#10;setPinFun(14, SECOND_FUNCTION);</field><next><block type="serial_begin" id="robot-uart-init"><field name="serial_select">Serial</field><field name="TX">PB_5</field><field name="RX">PB_6</field><value name="CONTENT"><shadow type="baud" id="robot-uart-baud"><field name="baud">9600</field></shadow></value></block></next></block></statement></block>

  <block type="procedures_defnoreturn" id="robot-asr-code" x="1360" y="20"><field name="NAME">ASR_CODE</field><comment pinned="false" h="80" w="180">语音识别成功后向树莓派发送单字节控制事件。</comment><statement name="STACK"><block type="block_with_textarea" id="robot-command-switch"><field name="input">set_state_enter_wakeup(15000);&#10;switch (snid) {&#10;  case 1000:&#10;  case 1001: Serial.write(0xA0); break;&#10;  case 1002: Serial.write(0xA1); break;&#10;  case 1003: Serial.write(0xA2); break;&#10;  case 1004: Serial.write(0xA3); break;&#10;  case 1005: Serial.write(0xA4); break;&#10;  case 1006: Serial.write(0xA5); break;&#10;  case 1007:&#10;  case 1008: Serial.write(0xA6); break;&#10;  case 1009: Serial.write(0xA7); break;&#10;  case 1010: Serial.write(0xA8); break;&#10;  case 1011: Serial.write(0xA9); break;&#10;  case 1012: Serial.write(0xAA); break;&#10;  case 1013: Serial.write(0xAB); break;&#10;}</field><next><block type="controls_if" id="include-audio-api"><value name="IF0"><block type="logic_boolean" id="include-audio-api-false"><field name="BOOL">FALSE</field></block></value><statement name="DO0"><block type="asr_event_play_audio" id="include-audio-api-prompt"><field name="audio">传感器数据暂不可用。</field></block></statement></block></next></block></statement></block>

  <block type="thread_app" id="robot-reply-thread" x="1360" y="520"><field name="app_name">voice_reply_task</field><field name="uxPriority">4</field><field name="mem">768</field><statement name="DO"><block type="controls_repeat_forever" id="reply-loop"><statement name="DO"><block type="block_with_textarea" id="reply-switch"><field name="input">static bool dynamic_active = false;&#10;static uint8_t dynamic_body[6];&#10;static uint8_t dynamic_index = 0;&#10;&#10;if (Serial.available() &gt; 0) {&#10;  uint8_t value = (uint8_t)Serial.read();&#10;  if (dynamic_active) {&#10;    dynamic_body[dynamic_index++] = value;&#10;    if (dynamic_index &gt;= 6) {&#10;      dynamic_active = false;&#10;      dynamic_index = 0;&#10;      uint8_t checksum = 0xE0;&#10;      for (uint8_t index = 0; index &lt; 5; index++) checksum ^= dynamic_body[index];&#10;      if (checksum == dynamic_body[5]) {&#10;        prompt_play_info_t prompts[16];&#10;        uint8_t prompt_count = 0;&#10;        auto append_prompt = [&amp;](uint16_t id) {&#10;          if (prompt_count &lt; 16) {&#10;            prompts[prompt_count].cmd_id = id;&#10;            prompts[prompt_count].select_index = (uint16_t)-1;&#10;            prompt_count++;&#10;          }&#10;        };&#10;        auto append_digit = [&amp;](uint8_t digit) { append_prompt((uint16_t)(2109 + (digit % 10))); };&#10;        auto append_integer = [&amp;](uint16_t number) {&#10;          if (number == 0) { append_digit(0); return; }&#10;          bool has_high_unit = false;&#10;          if (number &gt;= 1000) {&#10;            append_digit((uint8_t)(number / 1000)); append_prompt(2121); number %= 1000; has_high_unit = true;&#10;            if (number &gt; 0 &amp;&amp; number &lt; 100) append_digit(0);&#10;          }&#10;          if (number &gt;= 100) {&#10;            append_digit((uint8_t)(number / 100)); append_prompt(2120); number %= 100; has_high_unit = true;&#10;            if (number &gt; 0 &amp;&amp; number &lt; 10) append_digit(0);&#10;          }&#10;          if (number &gt;= 10) {&#10;            uint8_t tens = (uint8_t)(number / 10);&#10;            if (tens &gt; 1 || has_high_unit) append_digit(tens);&#10;            append_prompt(2119); number %= 10;&#10;          }&#10;          if (number &gt; 0) append_digit((uint8_t)number);&#10;        };&#10;        if (dynamic_body[0] == 0x01) {&#10;          int16_t temperature = (int16_t)(((uint16_t)dynamic_body[1] &lt;&lt; 8) | dynamic_body[2]);&#10;          int16_t humidity = (int16_t)(((uint16_t)dynamic_body[3] &lt;&lt; 8) | dynamic_body[4]);&#10;          int32_t temp_value = temperature;&#10;          int32_t humidity_value = humidity;&#10;          append_prompt(2101);&#10;          if (temp_value &lt; 0) { append_prompt(2108); temp_value = -temp_value; }&#10;          append_integer((uint16_t)(temp_value / 10)); append_prompt(2107); append_digit((uint8_t)(temp_value % 10)); append_prompt(2104);&#10;          append_prompt(2102);&#10;          if (humidity_value &lt; 0) { append_prompt(2108); humidity_value = -humidity_value; }&#10;          append_integer((uint16_t)(humidity_value / 10)); append_prompt(2107); append_digit((uint8_t)(humidity_value % 10)); append_prompt(2105);&#10;        } else if (dynamic_body[0] == 0x02) {&#10;          uint16_t distance = (uint16_t)(((uint16_t)dynamic_body[1] &lt;&lt; 8) | dynamic_body[2]);&#10;          append_prompt(2103); append_integer(distance); append_prompt(2106);&#10;        }&#10;        if (prompt_count &gt; 0) {&#10;          while (prompt_play_by_multi_cmd_id(prompts, prompt_count, NULL) != 0) delay(6);&#10;        }&#10;      }&#10;    }&#10;  } else if (value == 0xE0) {&#10;    dynamic_active = true;&#10;    dynamic_index = 0;&#10;  } else {&#10;    switch (value) {&#10;      case 0xF1: play_audio(2000); break;&#10;      case 0xF2: play_audio(2001); break;&#10;      case 0xF3: play_audio(2002); break;&#10;      case 0xF4: play_audio(2003); break;&#10;      case 0xF5: play_audio(2004); break;&#10;      case 0xF6: play_audio(2005); break;&#10;      case 0xF7: play_audio(2006); break;&#10;      case 0xF8: play_audio(2007); break;&#10;      case 0xF9: play_audio(2008); break;&#10;      case 0xFA: play_audio(2009); break;&#10;      case 0xFB: play_audio(2010); break;&#10;      case 0xFC: play_audio(2011); break;&#10;      case 0xFD: play_audio(2012); break;&#10;      case 0xFE: play_audio(2100); break;&#10;      default: break;&#10;    }&#10;  }&#10;}&#10;delay(10);</field></block></statement></block></statement></block>
</xml>
