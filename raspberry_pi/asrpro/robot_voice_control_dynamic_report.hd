  <block type="asr_add_id" id="dynamic-one" x="760" y="620"><field name="NAME">一</field><field name="id">2110</field></block>
  <block type="asr_add_id" id="dynamic-two" x="760" y="680"><field name="NAME">二</field><field name="id">2111</field></block>
  <block type="asr_add_id" id="dynamic-three" x="760" y="740"><field name="NAME">三</field><field name="id">2112</field></block>
  <block type="asr_add_id" id="dynamic-four" x="760" y="800"><field name="NAME">四</field><field name="id">2113</field></block>
  <block type="asr_add_id" id="dynamic-five" x="760" y="860"><field name="NAME">五</field><field name="id">2114</field></block>
  <block type="asr_add_id" id="dynamic-six" x="760" y="920"><field name="NAME">六</field><field name="id">2115</field></block>
