<xml xmlns="http://www.w3.org/1999/xhtml">
  <block type="asr_speak_baidu" id="voice-provider" x="20" y="20"><field name="VOICE_SET_BAIDU">小蝶-甜美女声</field><field name="vol">16</field><field name="speed">8</field></block>
  <block type="asr_welcom" id="voice-welcome" x="20" y="90"><field name="NAME">智能巡检语音助手已启动，请说小星小星。</field></block>
  <block type="asr_sleep" id="voice-sleep" x="20" y="150"><field name="NAME">语音助手已休眠，请说小星小星。</field></block>

  <block type="asr_id" id="wake-one" x="20" y="220"><field name="ASR">小星小星</field><field name="leibie">唤醒词</field><field name="huifu">我在，请说指令。</field><field name="id">1000</field></block>
  <block type="asr_id" id="wake-two" x="20" y="280"><field name="ASR">巡检小车</field><field name="leibie">唤醒词</field><field name="huifu">我在，请说指令。</field><field name="id">1001</field></block>
  <block type="asr_id" id="patrol-start" x="20" y="340"><field name="ASR">开始巡检</field><field name="leibie">命令词</field><field name="huifu">已发送开始巡检请求。</field><field name="id">1002</field></block>
  <block type="asr_id" id="patrol-pause" x="20" y="400"><field name="ASR">暂停巡检</field><field name="leibie">命令词</field><field name="huifu">已发送暂停巡检请求。</field><field name="id">1003</field></block>
  <block type="asr_id" id="patrol-resume" x="20" y="460"><field name="ASR">继续巡检</field><field name="leibie">命令词</field><field name="huifu">已发送继续巡检请求。</field><field name="id">1004</field></block>
  <block type="asr_id" id="patrol-stop" x="20" y="520"><field name="ASR">停止巡检</field><field name="leibie">命令词</field><field name="huifu">已发送立即停车请求。</field><field name="id">1005</field></block>
  <block type="asr_id" id="status" x="20" y="580"><field name="ASR">报告状态</field><field name="leibie">命令词</field><field name="huifu">正在请求系统状态。</field><field name="id">1006</field></block>
  <block type="asr_id" id="help" x="20" y="640"><field name="ASR">救命</field><field name="leibie">命令词</field><field name="huifu">紧急事件已上报。</field><field name="id">1007</field></block>
  <block type="asr_id" id="fire" x="20" y="700"><field name="ASR">着火了</field><field name="leibie">命令词</field><field name="huifu">紧急事件已上报。</field><field name="id">1008</field></block>
  <block type="asr_id" id="clear-alarm" x="20" y="760"><field name="ASR">解除报警</field><field name="leibie">命令词</field><field name="huifu">解除报警需要星闪端确认。</field><field name="id">1009</field></block>
  <block type="asr_id" id="environment" x="20" y="820"><field name="ASR">报告温湿度</field><field name="leibie">命令词</field><field name="huifu">正在查询温湿度。</field><field name="id">1010</field></block>
  <block type="asr_id" id="distance" x="20" y="880"><field name="ASR">前方距离</field><field name="leibie">命令词</field><field name="huifu">正在查询前方距离。</field><field name="id">1011</field></block>
  <block type="asr_id" id="patrol-report" x="20" y="940"><field name="ASR">巡检进度</field><field name="leibie">命令词</field><field name="huifu">正在查询巡检进度。</field><field name="id">1012</field></block>
  <block type="asr_id" id="battery" x="20" y="1000"><field name="ASR">报告电量</field><field name="leibie">命令词</field><field name="huifu">正在查询电量状态。</field><field name="id">1013</field></block>

